# Deployment Configuration
# Copy this file to .env.deploy and fill in your values
# IMPORTANT: Never commit .env.deploy to Git!

# === SSH Configuration ===
# Your VPS hostname or IP address
SSH_HOST=your-vps-host.com

# SSH username
SSH_USER=deploy

# Path to SSH private key (local machine)
# Generate with: ssh-keygen -t ed25519 -f ~/.ssh/deploy_key
SSH_KEY=${HOME}/.ssh/deploy_key

# === Deployment Configuration ===
# Remote deployment directory
# Example: /home/deploy/app
DEPLOY_PATH=/home/deploy/laravel

# Git branch to deploy
# Default: main
GIT_BRANCH=main

# Build Docker images locally or pull from registry
# Set to 'true' to build, 'false' to pull
BUILD_IMAGES=false

# === Docker Registry ===
# Docker registry for pushing/pulling images
# Example: ghcr.io/your-org/your-repo
DOCKER_REGISTRY=ghcr.io/your-org/your-repo

# === Database Configuration ===
# Database password for MySQL
# IMPORTANT: Keep this secure!
DB_PASSWORD=your-secure-password-here

# === Application Secrets ===
# Laravel APP_KEY (generate with: php artisan key:generate)
APP_KEY=base64:your-app-key-here

# === Optional Settings ===
# Enable notifications (Slack, Discord, etc.)
NOTIFY_ON_SUCCESS=true
NOTIFY_ON_FAILURE=true

# Slack webhook URL (optional)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Discord webhook URL (optional)
# DISCORD_WEBHOOK_URL=https://discordapp.com/api/webhooks/YOUR/WEBHOOK/URL

# === Backup Settings ===
# Keep last N backups
KEEP_BACKUPS=5

# Email for deployment notifications (optional)
NOTIFY_EMAIL=deploy@example.com

# === Performance Settings ===
# Timeout for SSH commands (seconds)
SSH_TIMEOUT=300

# Max retries for failed commands
MAX_RETRIES=3

# === Security ===
# Disable SSL verification (NOT recommended for production)
# CURL_INSECURE=false

# === Logging ===
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Store logs in specific directory
# Default: current directory
LOG_DIR=./deploy/logs
